rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Dados de empresa — requer autenticação ────────────────────────────
    match /empresas/{empresaId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Perfis de usuário ─────────────────────────────────────────────────
    match /usuarios/{userId} {
      allow read, write: if request.auth != null;
    }

    // ── Questionários públicos (COPSOQ) ───────────────────────────────────
    // Config: leitura pública (link de resposta), escrita só autenticado
    match /questionarios_publicos/{questionarioId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;

      // Respostas: qualquer pessoa pode enviar, só autenticado pode ler
      match /respostas/{respostaId} {
        allow create: if true;
        allow read:   if request.auth != null;
        allow update, delete: if false;
      }
    }

    // ── Links públicos de coleta IBUTG (Estresse Térmico) ─────────────────
    // Config: leitura pública (link de coleta em campo), escrita só autenticado
    match /avaliacoes_ibutg_publicas/{linkId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
